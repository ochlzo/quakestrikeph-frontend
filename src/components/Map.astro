---
/**
 * Map.astro
 *
 * A Leaflet map component that defaults to showing the Philippines.
 * Uses client-side vanilla JS — no framework integration required.
 *
 * Props:
 *   lat     - Initial center latitude  (default: 12.8797 — Philippines)
 *   lng     - Initial center longitude (default: 121.7740 — Philippines)
 *   zoom    - Initial zoom level       (default: 6)
 *   height  - CSS height of the map    (default: "500px")
 *   id      - Unique DOM id for the map container (default: "leaflet-map")
 */
interface Props {
  lat?: number;
  lng?: number;
  zoom?: number;
  height?: string;
  id?: string;
}

const {
  lat = 12.8797,
  lng = 121.774,
  zoom = 6,
  height = "500px",
  id = "leaflet-map",
} = Astro.props;
---

<!-- Leaflet CSS -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div
  id={id}
  data-lat={lat}
  data-lng={lng}
  data-zoom={zoom}
  style={`height: ${height}; width: 100%; border-radius: 12px; overflow: hidden;`}
  aria-label="Interactive map of the Philippines"
  role="application"
></div>

<script>
  // Astro <script> tags without define:vars are treated as ESM modules,
  // so `import` works correctly here. Props are passed via data-* attributes.
  import L from "leaflet";

  // Fix missing default marker icons when bundled (Leaflet asset path issue).
  // See: https://github.com/Leaflet/Leaflet/issues/4968
  delete (L.Icon.Default.prototype as any)._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconRetinaUrl:
      "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png",
    iconUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png",
    shadowUrl:
      "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
  });

  // Read props from data-* attributes.
  // querySelectorAll handles multiple <Map /> instances on the same page.
  document.querySelectorAll("[data-lat][data-lng][data-zoom]").forEach((el) => {
    const htmlEl = el as HTMLElement;
    const lat = parseFloat(htmlEl.dataset.lat!);
    const lng = parseFloat(htmlEl.dataset.lng!);
    const zoom = parseInt(htmlEl.dataset.zoom!, 10);

    // Bounding box that covers the entire Philippine archipelago with some padding.
    const philippinesBounds = L.latLngBounds(
      L.latLng(4.0, 114.0),   // Southwest corner
      L.latLng(22.5, 128.0),  // Northeast corner
    );

    const map = L.map(htmlEl, {
      center: [lat, lng],
      zoom,
      minZoom: 5,                          // Can't zoom out past seeing the whole PH
      maxBounds: philippinesBounds,        // Pan is restricted to this box
      maxBoundsViscosity: 1.0,            // 1.0 = hard wall, 0.0 = soft/elastic
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    }).addTo(map);
  });
</script>
